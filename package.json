{
  "name": "streaming-next",
  "private": true,
  "version": "1.9.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "test:run": "vitest --run",
    "test:dev": "vitest",
    "test:ui": "vitest --ui",
    "check": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:staged": "lint-staged",
    "preinstall": "bunx only-allow bun",
    "postinstall": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run check && bun run lint:staged && bun run test:run"
  },
  "lint-staged": {
    "**/*.{mjs,js,mts,ts,vue}": [
      "eslint"
    ]
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.13.6",
    "core-js": "^3.48.0",
    "lodash": "^4.17.23",
    "mitt": "^3.0.1",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "mousetrap": "^1.6.5",
    "pinia": "^3.0.4",
    "roboto-fontface": "^0.10.0",
    "toastr": "^2.1.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@mdi/js": "^7.4.47",
    "@pinia/testing": "^1.0.3",
    "@types/chrome": "^0.1.37",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/lodash": "^4.17.24",
    "@types/moment-duration-format": "^2.2.7",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^25.5.0",
    "@types/toastr": "^2.1.43",
    "@types/uuid": "^11.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "@webext-core/fake-browser": "^1.3.4",
    "@webext-core/storage": "^1.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuetify": "^2.7.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "jsdom-global": "^3.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vite-plugin-web-extension": "^4.5.0",
    "vitest": "^4.1.0",
    "vitest-browser-vue": "^2.1.0",
    "vitest-chrome": "^0.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5",
    "webextension-polyfill": "^0.12.0"
  }
}
